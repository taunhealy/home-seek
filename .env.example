# --- AI & Scraper ---
GEMINI_API_KEY=your_gemini_api_key_here
BROWSERLESS_URL=wss://chrome.browserless.io?token=your_token_here # Optional: for residential proxies

# --- Firebase (Backend) ---
# Path to your Firebase Service Account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# --- WhatsApp (Evolution API) ---
EVOLUTION_API_URL=https://your-evolution-api-url.com
EVOLUTION_API_KEY=your_api_key
EVOLUTION_INSTANCE_NAME=your_instance_name

# --- Frontend (copy these to web/.env.local) ---
NEXT_PUBLIC_FIREBASE_API_KEY=...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=...
NEXT_PUBLIC_FIREBASE_PROJECT_ID=...
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=...
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
NEXT_PUBLIC_FIREBASE_APP_ID=...
